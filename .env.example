# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-min-32-chars"
ADMIN_JWT_SECRET="your-admin-jwt-secret-min-32-chars"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ─── Email (optional locally — mocked to console if missing) ──────────────────
RESEND_API_KEY="re_your_resend_key"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create these in your Stripe dashboard
STRIPE_PRICE_SOLO_MONTHLY="price_..."
STRIPE_PRICE_SOLO_YEARLY="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."
STRIPE_PRICE_BUSINESS_MONTHLY="price_..."
STRIPE_PRICE_BUSINESS_YEARLY="price_..."

# ─── Supabase Storage ─────────────────────────────────────────────────────────
# Create a public bucket named "uploads" in your Supabase dashboard before
# using logo upload (Settings) or profile photo upload (Profile edit).
